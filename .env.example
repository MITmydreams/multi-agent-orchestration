# ==========================================
# Multi-Account Messaging Orchestrator
# Copy to .env and replace xxxx with real values (never commit .env)
# ==========================================

# --- AI API ---
ANTHROPIC_API_KEY=xxxx
ANTHROPIC_BASE_URL=xxxx
OPENAI_API_KEY=xxxx
AI_PROVIDER=anthropic
AI_MODEL=xxxx

# --- Telegram ---
TG_BOT_TOKEN=xxxx
TG_API_ID=xxxx
TG_API_HASH=xxxx

# --- Database ---
DATABASE_URL=postgresql+asyncpg://ops:ops@localhost:5432/ops_orchestrator
REDIS_URL=redis://localhost:6379/0

# --- Proxy ---
PROXY_PROVIDER=xxxx
PROXY_API_KEY=xxxx
PROXY_POOL_SIZE=10
LOCAL_VPN_HOST=xxxx
LOCAL_VPN_PORT=xxxx
LOCAL_VPN_PROTOCOL=socks5

# --- Product API (generic integration) ---
PRODUCT_API_URL=https://api.example.com
PRODUCT_API_KEY=xxxx
PRODUCT_WS_URL=wss://ws.example.com
PRODUCT_APP_URL=https://t.me/example_bot/app

# --- Risk Thresholds ---
RISK_THRESHOLD_SLOW=0.4
RISK_THRESHOLD_STRICT=0.5
RISK_THRESHOLD_HIBERNATE=0.65
RISK_THRESHOLD_ABANDON=0.8

# --- Rate Limits ---
MAX_MESSAGES_PER_DAY=30
MAX_GROUPS_PER_DAY=8
MAX_DMS_PER_DAY=3
MAX_LINKS_PER_DAY=3
OUTREACH_RATIO_LIMIT=0.2

# --- Scheduling ---
SCHEDULER_INTERVAL_SECONDS=60
NURTURE_DAYS=45
ENGAGEMENT_COOLDOWN_DAYS=14

# --- General ---
LOG_LEVEL=INFO
ENVIRONMENT=development
