# ==========================================
# The Button - Promo Bot Configuration
# Copy to .env and fill in real values
# ==========================================

# --- AI API ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-20250514

# --- Telegram ---
TG_BOT_TOKEN=
TG_API_ID=0
TG_API_HASH=

# --- Database ---
DATABASE_URL=postgresql+asyncpg://promo:promo@localhost:5432/promo_bot
REDIS_URL=redis://localhost:6379/0

# --- Proxy ---
PROXY_PROVIDER=brightdata
PROXY_API_KEY=
PROXY_POOL_SIZE=60

# --- Game API ---
GAME_API_URL=https://api.thebutton.game
GAME_API_KEY=
GAME_WS_URL=wss://ws.thebutton.game

# --- Risk Thresholds ---
RISK_THRESHOLD_SLOW=0.4
RISK_THRESHOLD_STRICT=0.5
RISK_THRESHOLD_HIBERNATE=0.65
RISK_THRESHOLD_ABANDON=0.8

# --- Rate Limits ---
MAX_MESSAGES_PER_DAY=30
MAX_GROUPS_PER_DAY=8
MAX_DMS_PER_DAY=3
MAX_LINKS_PER_DAY=3
PROMO_RATIO_LIMIT=0.2

# --- Scheduling ---
SCHEDULER_INTERVAL_SECONDS=60
NURTURE_DAYS=45
INFILTRATION_COOLDOWN_DAYS=14

# --- General ---
LOG_LEVEL=INFO
ENVIRONMENT=development
